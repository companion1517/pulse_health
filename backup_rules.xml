<?xml version="1.0" encoding="utf-8"?>
<!-- Exclude WebView persistent data from Google cloud backup.
     User health data stays on-device. -->
<full-backup-content>
    <exclude domain="database" path="." />
    <exclude domain="file" path="app_webview/" />
    <exclude domain="sharedpref" path="." />
</full-backup-content>
